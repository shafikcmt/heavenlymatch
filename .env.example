APP_NAME="HeavenlyMatch"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=heavenlymatch
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail ──────────────────────────────────────────────────────────────────────
# Local dev: use "log" — emails go to storage/logs/laravel.log, no SMTP needed.
# Shared hosting: set MAIL_MAILER=smtp and fill in cPanel / Zoho / Gmail SMTP.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@heavenlymatch.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Queue ─────────────────────────────────────────────────────────────────────
# sync     = process inline (simple shared hosting, no worker needed)
# database = queue in jobs table; run: php artisan queue:work --once via cron
# QUEUE_CONNECTION=database

# ── Social OAuth (optional) ───────────────────────────────────────────────────
# Google: https://console.developers.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Facebook: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# Twilio SMS — registration phone OTP. https://console.twilio.com
# Leave blank in local: OTP codes are written to storage/logs/laravel.log instead.
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# =============================================================================
# PRODUCTION OVERRIDES — copy these into your live .env and adjust values
# =============================================================================
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://yourdomain.com
#
# DB_HOST=localhost
# DB_DATABASE=cpanel_dbname
# DB_USERNAME=cpanel_dbuser
# DB_PASSWORD=strong_password_here
#
# SESSION_DRIVER=file
# SESSION_DOMAIN=yourdomain.com
# SESSION_SECURE_COOKIE=true
#
# CACHE_DRIVER=file
# QUEUE_CONNECTION=sync
#
# MAIL_MAILER=smtp
# MAIL_HOST=mail.yourdomain.com
# MAIL_PORT=465
# MAIL_USERNAME=noreply@yourdomain.com
# MAIL_PASSWORD=your_smtp_password
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
#
# LOG_LEVEL=error
# LOG_CHANNEL=single
