APP_NAME="HeavenlyMatch"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=heavenlymatch
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail ─────────────────────────────────────────────────────────────────────
# Local dev: use "log" — emails go to storage/logs/laravel.log, no SMTP needed.
# Shared hosting: set MAIL_MAILER=smtp and fill in cPanel / Zoho / Gmail SMTP below.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@heavenlymatch.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Queue ─────────────────────────────────────────────────────────────────────
# sync  = emails send immediately (good for small sites / shared hosting)
# database = emails queued in jobs table; run: php artisan queue:work --once
# redis = requires Redis server (NOT required for this project)
# QUEUE_CONNECTION=database

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ── Storage ───────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# For private photo storage, photos go to storage/app/private/
# Run: php artisan storage:link  (creates public/storage symlink)
